---
import '../styles/global.css'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/app-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Run Claude and Codex side by side in a multi-pane terminal. Compare responses. Switch instantly." />
		<title>inferay - Multi-Model AI Terminal</title>
	</head>
	<body class="bg-black text-white min-h-screen antialiased">

		<!-- Header -->
		<header class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
			<nav class="max-w-6xl mx-auto flex items-center justify-between">
				<div class="flex items-center gap-3">
					<img src="/app-icon.png" alt="inferay" class="w-8 h-8 rounded-lg" />
					<span class="text-lg font-semibold tracking-tight">inferay</span>
				</div>
				<a
					href="/inferay-installer.dmg"
					download
					class="text-sm text-zinc-400 hover:text-white transition-colors"
				>
					Download
				</a>
			</nav>
		</header>

		<main class="max-w-3xl mx-auto px-6 pt-40 pb-24">

			<!-- Hero -->
			<section class="mb-32">
				<h1 class="text-5xl md:text-6xl font-semibold tracking-tight leading-tight mb-6">
					Every model.<br />One interface.
				</h1>
				<p class="text-xl text-zinc-500 max-w-lg mb-10 leading-relaxed">
					Run Claude and Codex side by side in a multi-pane terminal. Compare responses. Switch instantly.
				</p>
				<div class="flex items-center gap-6">
					<a
						href="/inferay-installer.dmg"
						download
						class="inline-flex items-center gap-2 bg-white text-black px-6 py-3 rounded-lg font-medium text-sm hover:bg-zinc-200 transition-colors"
					>
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
						</svg>
						Download for macOS
					</a>
					<span class="text-sm text-zinc-600">macOS 12+ &middot; Apple Silicon</span>
				</div>
			</section>

			<!-- Features -->
			<section class="mb-32">
				<div class="space-y-16">
					<div>
						<h2 class="text-zinc-400 text-sm uppercase tracking-wider mb-4">Multi-Agent</h2>
						<p class="text-2xl text-zinc-300 leading-relaxed">
							Claude and Codex in split panes. Compare responses. Use the right agent for the job.
						</p>
					</div>

					<div>
						<h2 class="text-zinc-400 text-sm uppercase tracking-wider mb-4">Your Keys</h2>
						<p class="text-2xl text-zinc-300 leading-relaxed">
							Connect with your own API keys. No middleman. No subscriptions. Direct access.
						</p>
					</div>

					<div>
						<h2 class="text-zinc-400 text-sm uppercase tracking-wider mb-4">Terminal Native</h2>
						<p class="text-2xl text-zinc-300 leading-relaxed">
							Real PTY sessions alongside AI chat. Slash commands. 12 themes. Keyboard-first workflow.
						</p>
					</div>

					<div>
						<h2 class="text-zinc-400 text-sm uppercase tracking-wider mb-4">Fast</h2>
						<p class="text-2xl text-zinc-300 leading-relaxed">
							Built on Bun. Streaming responses. Native macOS app. No Electron bloat.
						</p>
					</div>
				</div>
			</section>

			<!-- Bottom CTA -->
			<section class="border-t border-zinc-900 pt-16">
				<p class="text-zinc-600 mb-6">Ready to try it?</p>
				<a
					href="/inferay-installer.dmg"
					download
					class="inline-flex items-center gap-2 text-white hover:text-zinc-400 transition-colors"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
					</svg>
					Download inferay
				</a>
			</section>

		</main>

	</body>
</html>
