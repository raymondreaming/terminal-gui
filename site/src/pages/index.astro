---
import "../styles/global.css";
import Inferay from "../components/Inferay";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/app-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Run Claude, GPT, and Codex side by side in a multi-pane terminal. Compare responses. Switch instantly. One interface for every model." />
		<title>inferay - The Multi-Model AI Terminal</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0a0a] text-white min-h-screen antialiased font-sans overflow-x-hidden">

		<!-- Hero Background - Forest with enhanced effects -->
		<div class="fixed inset-0 -z-10 overflow-hidden">
			<!-- Background image with slight zoom and slow drift animation -->
			<div class="absolute inset-0 scale-110 animate-slow-drift">
				<img
					src="/hero-bg.png"
					alt=""
					class="w-full h-full object-cover"
					style="filter: saturate(1.1) contrast(1.0) brightness(1.05);"
				/>
			</div>

			<!-- Grid overlay with radial fade -->
			<div class="absolute inset-0" style="
				background-image:
					linear-gradient(rgba(255,255,255,0.12) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255,255,255,0.12) 1px, transparent 1px);
				background-size: 50px 50px;
				mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
				-webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
			"></div>

			<!-- Perspective grid floor effect -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none" style="
				perspective: 1000px;
				perspective-origin: 50% 30%;
			">
				<div class="absolute left-0 right-0 bottom-0 h-[60%]" style="
					background-image:
						linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
						linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
					background-size: 80px 80px;
					transform: rotateX(60deg);
					transform-origin: bottom center;
					mask-image: linear-gradient(to top, black 0%, transparent 80%);
					-webkit-mask-image: linear-gradient(to top, black 0%, transparent 80%);
				"></div>
			</div>

			<!-- Glowing grid intersection points -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none">
				<div class="grid-dot" style="left: 20%; top: 30%;"></div>
				<div class="grid-dot" style="left: 80%; top: 25%; animation-delay: 1s;"></div>
				<div class="grid-dot" style="left: 40%; top: 70%; animation-delay: 2s;"></div>
				<div class="grid-dot" style="left: 60%; top: 50%; animation-delay: 0.5s;"></div>
				<div class="grid-dot" style="left: 10%; top: 60%; animation-delay: 1.5s;"></div>
				<div class="grid-dot" style="left: 90%; top: 80%; animation-delay: 2.5s;"></div>
			</div>

			<!-- Pulsing concentric circles -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none flex items-center justify-center">
				<div class="concentric-ring" style="width: 400px; height: 400px;"></div>
				<div class="concentric-ring" style="width: 700px; height: 700px; animation-delay: 1s;"></div>
				<div class="concentric-ring" style="width: 1000px; height: 1000px; animation-delay: 2s;"></div>
			</div>

			<!-- Floating soft orbs -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none">
				<div class="floating-orb" style="left: 15%; top: 20%; width: 300px; height: 300px; background: radial-gradient(circle, rgba(255,200,150,0.04) 0%, transparent 70%);"></div>
				<div class="floating-orb" style="left: 70%; top: 60%; width: 400px; height: 400px; background: radial-gradient(circle, rgba(200,220,255,0.03) 0%, transparent 70%); animation-delay: 3s;"></div>
				<div class="floating-orb" style="left: 50%; top: 40%; width: 250px; height: 250px; background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, transparent 70%); animation-delay: 6s;"></div>
			</div>

			<!-- Animated grid pulse from center -->
			<div class="grid-pulse"></div>

			<!-- Gradient overlay - lighter cinematic color grade -->
			<div class="absolute inset-0" style="
				background: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.05) 30%, rgba(0,0,0,0.25) 100%);
			"></div>

			<!-- Warm light leak from top-left -->
			<div class="absolute inset-0 animate-light-flicker" style="
				background:
					radial-gradient(ellipse 60% 60% at 15% 10%, rgba(255,180,100,0.12) 0%, transparent 50%),
					radial-gradient(ellipse 40% 40% at 25% 25%, rgba(255,200,150,0.08) 0%, transparent 50%);
			"></div>

			<!-- Center dark zone for interface focus -->
			<div class="absolute inset-0" style="
				background: radial-gradient(ellipse 65% 55% at 50% 55%, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.25) 40%, transparent 70%);
			"></div>

			<!-- Floating dust particles - warm golden motes -->
			<div class="absolute inset-0 overflow-hidden">
				<div class="dust-particle" style="left: 10%; top: 20%; animation-delay: 0s;"></div>
				<div class="dust-particle" style="left: 85%; top: 15%; animation-delay: 2s;"></div>
				<div class="dust-particle" style="left: 20%; top: 70%; animation-delay: 4s;"></div>
				<div class="dust-particle" style="left: 75%; top: 65%; animation-delay: 1s;"></div>
				<div class="dust-particle" style="left: 50%; top: 10%; animation-delay: 3s;"></div>
				<div class="dust-particle" style="left: 30%; top: 40%; animation-delay: 5s;"></div>
				<div class="dust-particle" style="left: 90%; top: 45%; animation-delay: 2.5s;"></div>
				<div class="dust-particle" style="left: 5%; top: 55%; animation-delay: 1.5s;"></div>
				<div class="dust-particle" style="left: 45%; top: 30%; animation-delay: 6s;"></div>
				<div class="dust-particle" style="left: 60%; top: 75%; animation-delay: 7s;"></div>
				<div class="dust-particle" style="left: 15%; top: 85%; animation-delay: 8s;"></div>
				<div class="dust-particle" style="left: 70%; top: 5%; animation-delay: 9s;"></div>
			</div>

			<!-- Sparkle stars - bright twinkling points -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none">
				<div class="sparkle" style="left: 8%; top: 12%;"></div>
				<div class="sparkle" style="left: 92%; top: 8%; animation-delay: 1.5s;"></div>
				<div class="sparkle" style="left: 15%; top: 35%; animation-delay: 0.8s;"></div>
				<div class="sparkle" style="left: 88%; top: 42%; animation-delay: 2.2s;"></div>
				<div class="sparkle" style="left: 5%; top: 68%; animation-delay: 3s;"></div>
				<div class="sparkle" style="left: 95%; top: 75%; animation-delay: 0.5s;"></div>
				<div class="sparkle" style="left: 22%; top: 88%; animation-delay: 1.8s;"></div>
				<div class="sparkle" style="left: 78%; top: 92%; animation-delay: 2.8s;"></div>
				<div class="sparkle large" style="left: 12%; top: 25%; animation-delay: 0.3s;"></div>
				<div class="sparkle large" style="left: 85%; top: 30%; animation-delay: 1.2s;"></div>
				<div class="sparkle large" style="left: 18%; top: 72%; animation-delay: 2.5s;"></div>
				<div class="sparkle large" style="left: 82%; top: 65%; animation-delay: 3.5s;"></div>
			</div>

			<!-- Light rays streaming through trees -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none opacity-20">
				<div class="light-ray" style="left: 20%; transform: rotate(15deg);"></div>
				<div class="light-ray" style="left: 35%; transform: rotate(8deg); animation-delay: 2s;"></div>
				<div class="light-ray" style="left: 65%; transform: rotate(-5deg); animation-delay: 4s;"></div>
				<div class="light-ray" style="left: 80%; transform: rotate(-12deg); animation-delay: 1s;"></div>
			</div>

			<!-- Atmospheric mist layers -->
			<div class="absolute inset-0 opacity-30" style="
				background:
					radial-gradient(ellipse 120% 40% at 10% 90%, rgba(255,255,255,0.08) 0%, transparent 50%),
					radial-gradient(ellipse 100% 35% at 90% 85%, rgba(255,255,255,0.06) 0%, transparent 50%),
					radial-gradient(ellipse 80% 30% at 50% 95%, rgba(255,255,255,0.04) 0%, transparent 40%);
			"></div>

			<!-- Soft glow behind interface area -->
			<div class="absolute top-[35%] left-1/2 -translate-x-1/2 w-[1400px] h-[900px]" style="
				background: radial-gradient(ellipse 70% 50% at 50% 45%, rgba(255,240,220,0.035) 0%, transparent 50%);
				filter: blur(60px);
			"></div>

			<!-- Softer cinematic vignette -->
			<div class="absolute inset-0" style="
				background: radial-gradient(ellipse 85% 80% at 50% 50%, transparent 20%, rgba(0,0,0,0.5) 100%);
			"></div>

			<!-- Subtle lens blur on edges -->
			<div class="absolute inset-0 pointer-events-none" style="
				box-shadow: inset 0 0 150px 30px rgba(0,0,0,0.2);
			"></div>

			<!-- Film grain texture -->
			<div class="absolute inset-0 opacity-[0.04] mix-blend-overlay animate-grain" style="
				background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');
			"></div>
		</div>

		<style>
			@keyframes slow-drift {
				0%, 100% { transform: scale(1.1) translate(0, 0); }
				50% { transform: scale(1.1) translate(-0.5%, -0.3%); }
			}
			@keyframes light-flicker {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.85; }
			}
			@keyframes float-up {
				0% { transform: translateY(100vh) scale(0); opacity: 0; }
				10% { opacity: 0.6; transform: translateY(90vh) scale(1); }
				90% { opacity: 0.3; }
				100% { transform: translateY(-10vh) scale(0.5); opacity: 0; }
			}
			@keyframes twinkle {
				0%, 100% { opacity: 0; transform: scale(0); }
				50% { opacity: 1; transform: scale(1); }
			}
			@keyframes ray-pulse {
				0%, 100% { opacity: 0.15; }
				50% { opacity: 0.3; }
			}
			@keyframes grain {
				0%, 100% { transform: translate(0, 0); }
				10% { transform: translate(-1%, -1%); }
				20% { transform: translate(1%, 1%); }
				30% { transform: translate(-1%, 1%); }
				40% { transform: translate(1%, -1%); }
				50% { transform: translate(-1%, 0%); }
				60% { transform: translate(1%, 0%); }
				70% { transform: translate(0%, 1%); }
				80% { transform: translate(0%, -1%); }
				90% { transform: translate(1%, 1%); }
			}
			.animate-slow-drift {
				animation: slow-drift 30s ease-in-out infinite;
			}
			.animate-light-flicker {
				animation: light-flicker 8s ease-in-out infinite;
			}
			.animate-grain {
				animation: grain 0.5s steps(10) infinite;
			}
			.dust-particle {
				position: absolute;
				width: 2px;
				height: 2px;
				background: rgba(255, 240, 200, 0.7);
				border-radius: 50%;
				box-shadow: 0 0 8px 3px rgba(255, 220, 180, 0.4);
				animation: float-up 18s linear infinite;
			}
			.sparkle {
				position: absolute;
				width: 3px;
				height: 3px;
				background: white;
				border-radius: 50%;
				box-shadow:
					0 0 4px 1px rgba(255, 255, 255, 0.8),
					0 0 8px 2px rgba(255, 255, 255, 0.4),
					0 0 12px 4px rgba(255, 240, 200, 0.3);
				animation: twinkle 3s ease-in-out infinite;
			}
			.sparkle.large {
				width: 4px;
				height: 4px;
				box-shadow:
					0 0 6px 2px rgba(255, 255, 255, 0.9),
					0 0 12px 4px rgba(255, 255, 255, 0.5),
					0 0 20px 6px rgba(255, 240, 200, 0.3);
				animation-duration: 4s;
			}
			.light-ray {
				position: absolute;
				top: -20%;
				width: 80px;
				height: 140%;
				background: linear-gradient(180deg, rgba(255,240,200,0.15) 0%, transparent 100%);
				filter: blur(30px);
				animation: ray-pulse 6s ease-in-out infinite;
			}
			@keyframes float-slow {
				0%, 100% { transform: translateY(0px); }
				50% { transform: translateY(-8px); }
			}
			.animate-float-slow {
				animation: float-slow 4s ease-in-out infinite;
			}
			@keyframes grid-dot-pulse {
				0%, 100% { opacity: 0; transform: scale(0.5); }
				50% { opacity: 0.6; transform: scale(1); }
			}
			.grid-dot {
				position: absolute;
				width: 4px;
				height: 4px;
				background: rgba(255, 255, 255, 0.8);
				border-radius: 50%;
				box-shadow: 0 0 10px 3px rgba(255, 255, 255, 0.3), 0 0 20px 6px rgba(255, 240, 200, 0.15);
				animation: grid-dot-pulse 4s ease-in-out infinite;
			}
			@keyframes orb-float {
				0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.5; }
				25% { transform: translate(20px, -30px) scale(1.1); opacity: 0.7; }
				50% { transform: translate(-10px, -50px) scale(1); opacity: 0.5; }
				75% { transform: translate(-30px, -20px) scale(0.9); opacity: 0.6; }
			}
			.floating-orb {
				position: absolute;
				border-radius: 50%;
				filter: blur(40px);
				animation: orb-float 20s ease-in-out infinite;
			}
			@keyframes ring-pulse {
				0% { transform: scale(0.8); opacity: 0.3; }
				50% { transform: scale(1); opacity: 0.1; }
				100% { transform: scale(1.2); opacity: 0; }
			}
			.concentric-ring {
				position: absolute;
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: 50%;
				animation: ring-pulse 6s ease-out infinite;
			}
			@keyframes grid-wave {
				0% { transform: scale(0); opacity: 0.4; }
				100% { transform: scale(3); opacity: 0; }
			}
			.grid-pulse {
				position: absolute;
				top: 50%;
				left: 50%;
				width: 200px;
				height: 200px;
				margin: -100px 0 0 -100px;
				border-radius: 50%;
				background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
				animation: grid-wave 8s ease-out infinite;
				pointer-events: none;
			}

			/* Hero animations */
			@keyframes hero-line-reveal {
				0% { opacity: 0; transform: translateY(20px) skewX(-2deg); filter: blur(8px); }
				100% { opacity: 1; transform: translateY(0) skewX(0); filter: blur(0); }
			}
			@keyframes hero-fade-in {
				0% { opacity: 0; transform: translateY(15px); }
				100% { opacity: 1; transform: translateY(0); }
			}
			@keyframes pulse-slow {
				0%, 100% { opacity: 0.5; }
				50% { opacity: 0.8; }
			}
			@keyframes shimmer {
				0% { background-position: -200% 0; }
				100% { background-position: 200% 0; }
			}
			.hero-headline {
				background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 25%, #ffffff 50%, #f5f5f5 75%, #ffffff 100%);
				background-size: 200% auto;
				-webkit-background-clip: text;
				background-clip: text;
				-webkit-text-fill-color: transparent;
				animation: shimmer 8s linear infinite;
				text-shadow: none;
			}
			.hero-line {
				opacity: 0;
				animation: hero-line-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.hero-fade {
				opacity: 0;
				animation: hero-fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
			}
			.animate-pulse-slow {
				animation: pulse-slow 4s ease-in-out infinite;
			}
			.model-pill {
				display: inline-flex;
				align-items: center;
				padding: 4px 10px;
				font-size: 12px;
				font-weight: 500;
				color: rgba(255,255,255,0.7);
				background: rgba(255,255,255,0.08);
				border: 1px solid rgba(255,255,255,0.1);
				border-radius: 20px;
				backdrop-filter: blur(4px);
				transition: all 0.2s;
			}
			.model-pill:hover {
				background: rgba(255,255,255,0.12);
				border-color: rgba(255,255,255,0.2);
				color: rgba(255,255,255,0.9);
			}
		</style>

		<!-- Header -->
		<header class="fixed top-0 left-0 right-0 z-50 px-4 py-4">
			<nav class="max-w-6xl mx-auto flex items-center justify-between px-5 py-3">
				<div class="flex items-center gap-3">
					<div class="relative">
						<div class="absolute -inset-1 bg-white/10 rounded-xl blur-md"></div>
						<img src="/app-icon.png" alt="inferay" class="relative w-10 h-10 rounded-xl shadow-lg" />
					</div>
					<span class="text-[16px] font-semibold tracking-tight">inferay</span>
				</div>
			</nav>
		</header>

		<main class="relative">

			<!-- Hero Section -->
			<section class="pt-32 pb-8 px-2 sm:px-4">
				<div class="text-center max-w-3xl mx-auto mb-10">
					<!-- Headline -->
					<h1 class="text-[clamp(2.5rem,7vw,4.5rem)] font-bold tracking-tight leading-[1.1] mb-5 text-white drop-shadow-lg">
						Every model.<br />One workflow.
					</h1>

					<!-- Subheadline with model pills -->
					<div class="hero-fade" style="animation-delay: 0.4s;">
						<div class="flex items-center justify-center gap-2 mb-4 flex-wrap">
							<span class="model-pill">Opus 4.7</span>
							<span class="text-white/30">·</span>
							<span class="model-pill">GPT-5.4</span>
							<span class="text-white/30">·</span>
							<span class="model-pill">Gemini 2.5</span>
							<span class="text-white/30">·</span>
							<span class="model-pill">Local Models</span>
						</div>
						<p class="text-[17px] text-white/60 max-w-lg mx-auto mb-8 leading-relaxed">
							Run them side by side. Compare in real-time. Switch mid-thought.
						</p>
					</div>

					<!-- Form with enhanced styling -->
					<div class="hero-fade relative max-w-md mx-auto" style="animation-delay: 0.6s;">
						<!-- Multi-layer glow behind form -->
						<div class="absolute -inset-8 bg-gradient-to-r from-amber-500/10 via-white/10 to-amber-500/10 rounded-3xl blur-2xl animate-pulse-slow"></div>
						<div class="absolute -inset-4 bg-white/5 rounded-2xl blur-xl"></div>
						<div class="relative" style="height: 52px;">
							<form id="waitlist-form" class="absolute inset-0 flex items-center gap-0">
								<input
									type="email"
									placeholder="Enter your email"
									required
									class="flex-1 h-full px-5 rounded-l-xl bg-black/60 backdrop-blur-md border border-white/20 border-r-0 text-white text-[15px] placeholder:text-white/40 outline-none focus:border-white/40 focus:bg-black/70 transition-all"
								/>
								<button
									type="submit"
									class="h-full px-7 rounded-r-xl bg-white text-black font-semibold text-[15px] hover:bg-white/95 hover:shadow-xl hover:shadow-white/20 transition-all whitespace-nowrap group"
								>
									<span class="group-hover:translate-x-0.5 transition-transform inline-block">Join waitlist</span>
								</button>
							</form>
							<p id="waitlist-success" class="hidden absolute inset-0 flex items-center justify-center text-[14px] text-green-400 font-medium">
								<svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
								You're on the list
							</p>
						</div>
					</div>
					<script>
						document.getElementById('waitlist-form')?.addEventListener('submit', function(e) {
							e.preventDefault();
							this.style.display = 'none';
							document.getElementById('waitlist-success')?.classList.remove('hidden');
						});
					</script>
				</div>

				<!-- Inferay UI -->
				<div class="w-full max-w-7xl mx-auto">
					<Inferay client:visible />
				</div>
			</section>

		</main>

		<!-- Footer -->
		<footer class="py-8 px-6">
			<div class="max-w-6xl mx-auto flex items-center justify-center">
				<p class="text-xs text-white/30">&copy; 2025 inferay</p>
			</div>
		</footer>

	</body>
</html>
