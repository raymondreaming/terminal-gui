{
	"name": "terminal-gui",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"dev": "bun index.ts",
		"start": "bun index.ts",
		"build:css": "bunx tailwindcss -i src/index.css -o dist/styles.css --minify",
		"build": "bun run build:css",
		"format": "bunx biome format --write ./src",
		"format:prettier": "prettier . --write",
		"check": "bunx biome check --write ./src"
	},
	"lint-staged": {
		"*": "prettier --write --ignore-unknown"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@tailwindcss/cli": "^4.2.1",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.2",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/xterm": "^6.0.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.1",
		"tailwindcss": "^4.2.1",
		"yaml": "^2.8.2"
	}
}
